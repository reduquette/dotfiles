{
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(BZL_TEST_RESULTS_VIEWER_ENABLED=true bzl:*)",
      "Bash(bzl:*)",
      "Bash(cat:*)",
      "Bash(ddtool auth:*)",
      "Bash(ddtool vault:*)",
      "Bash(diff:*)",
      "Bash(env:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(gh api:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(git branch:*)",
      "Bash(git check-ignore:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git grep:*)",
      "Bash(git log:*)",
      "Bash(git ls-files:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show-ref:*)",
      "Bash(git show:*)",
      "Bash(git stash list:*)",
      "Bash(git status:*)",
      "Bash(go:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jj abandon:*)",
      "Bash(jj bookmark create:*)",
      "Bash(jj bookmark delete:*)",
      "Bash(jj bookmark list:*)",
      "Bash(jj bookmark move:*)",
      "Bash(jj bookmark set:*)",
      "Bash(jj commit:*)",
      "Bash(jj config list:*)",
      "Bash(jj config:*)",
      "Bash(jj describe:*)",
      "Bash(jj diff:*)",
      "Bash(jj file list:*)",
      "Bash(jj git export:*)",
      "Bash(jj git import:*)",
      "Bash(jj git push:*)",
      "Bash(jj log:*)",
      "Bash(jj new:*)",
      "Bash(jj op:*)",
      "Bash(jj operation log:*)",
      "Bash(jj rebase:*)",
      "Bash(jj resolve --list:*)",
      "Bash(jj restore:*)",
      "Bash(jj show:*)",
      "Bash(jj split:*)",
      "Bash(jj squash:*)",
      "Bash(jj st:*)",
      "Bash(jj status:*)",
      "Bash(jj undo:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(printenv:*)",
      "Bash(pwd:*)",
      "Bash(realpath:*)",
      "Bash(shellcheck:*)",
      "Bash(tail:*)",
      "Bash(tr:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xxd:*)",
      "Edit",
      "Glob",
      "Grep",
      "Read",
      "Skill(confluence-api:confluence-api)",
      "Skill(dd:debug-ddci-request)",
      "Skill(dd:fetch-ci-results)",
      "Skill(dd:get-pr-feedback)",
      "Skill(dd:isolated-test)",
      "Skill(dd:render-helm)",
      "Skill(dd:whoisthis)",
      "Skill(slack:channel-digest)",
      "Skill(slack:find-discussions)",
      "Skill(slack:standup)",
      "Skill(slack:summarize-channel)",
      "Write",
      "mcp__atlassian__fetchAtlassian",
      "mcp__atlassian__getConfluencePage",
      "mcp__atlassian__searchAtlassian",
      "mcp__atlassian__updateConfluencePage"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f ~/.claude/settings.json ] && [ -f ~/dotfiles/.claude/settings.json ]; then NEW_ALLOW=$(jq -s '((.[0].permissions.allow // []) + (.[1].permissions.allow // [])) | unique | sort' ~/.claude/settings.json ~/dotfiles/.claude/settings.json) && NEW_DENY=$(jq -s '((.[0].permissions.deny // []) + (.[1].permissions.deny // [])) | unique | sort' ~/.claude/settings.json ~/dotfiles/.claude/settings.json) && NEW_PLUGINS=$(jq -s '((.[1].enabledPlugins // {}) * (.[0].enabledPlugins // {})) | to_entries | sort_by(.key) | from_entries' ~/.claude/settings.json ~/dotfiles/.claude/settings.json) && OLD_ALLOW=$(jq '(.permissions.allow // []) | unique | sort' ~/dotfiles/.claude/settings.json) && OLD_DENY=$(jq '(.permissions.deny // []) | unique | sort' ~/dotfiles/.claude/settings.json) && OLD_PLUGINS=$(jq '(.enabledPlugins // {}) | to_entries | sort_by(.key) | from_entries' ~/dotfiles/.claude/settings.json); if [ \"$NEW_ALLOW\" != \"$OLD_ALLOW\" ] || [ \"$NEW_DENY\" != \"$OLD_DENY\" ] || [ \"$NEW_PLUGINS\" != \"$OLD_PLUGINS\" ]; then jq --argjson allow \"$NEW_ALLOW\" --argjson deny \"$NEW_DENY\" --argjson plugins \"$NEW_PLUGINS\" '.permissions.allow = $allow | .permissions.deny = $deny | .enabledPlugins = $plugins' ~/dotfiles/.claude/settings.json > /tmp/.claude-perms-sync.tmp && mv /tmp/.claude-perms-sync.tmp ~/dotfiles/.claude/settings.json && echo '{\"systemMessage\": \"Settings synced to ~/dotfiles — remember to commit and push!\"}'; fi; fi"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "slack@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "permissions@mat-brown-contrib": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "dd@datadog-claude-plugins": true,
    "osx-notifications@datadog-claude-plugins": true,
    "redblue@datadog-claude-plugins": true,
    "go-code-reviewer@datadog-claude-plugins": true,
    "python-code-reviewer@datadog-claude-plugins": true,
    "marketplace-auto-update@datadog-claude-plugins": true,
    "orgstore@datadog-claude-plugins": true,
    "bits-dev@datadog-claude-plugins": true,
    "bits-remote-agent@datadog-claude-plugins": true,
    "rapid@datadog-claude-plugins": true,
    "git-mergetool@mat-brown-contrib": true,
    "branch-stacking-detection@mat-brown-contrib": true
  }
}
